{
  "name": "stapler-squad-e2e-tests",
  "version": "1.0.0",
  "description": "End-to-end tests for stapler-squad",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:review-queue": "playwright test review-queue.spec.ts",
    "report": "playwright show-report ../playwright-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "lighthouse": "lhci autorun --config=lighthouse.config.js"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.8.0",
    "@lhci/cli": "^0.13.0",
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "allure-commandline": "^2.30.0",
    "allure-playwright": "^3.7.1",
    "typescript": "^5.3.0"
  }
}
